# ─────────────────────────────────────────────────────────────────
# Mt Baw Baw Apartments — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────
# Supabase Transaction Pooler (port 6543) — recommended for Vercel serverless
# DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?sslmode=require"
#
# Local development (PostgreSQL running on localhost):
# DATABASE_URL="postgresql://appuser:apppass@localhost:5432/mtbawbaw"
DATABASE_URL=""

# ── Stripe ───────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Get from https://dashboard.stripe.com/webhooks (after creating a webhook endpoint)
# Endpoint URL: https://your-domain.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── App ──────────────────────────────────────────────────────────
# Set this to your production domain on Vercel
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Mt Baw Baw Apartments"

# ── Admin ────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@mtbawbawapartments.com"

# ── Email (booking confirmations & alerts) ───────────────────────
# Gmail example — use an App Password, not your main password
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="Mt Baw Baw Apartments <noreply@mtbawbawapartments.com>"

# ── Slack (optional — instant booking alerts) ────────────────────
SLACK_WEBHOOK_URL=""

# ── Pricing ──────────────────────────────────────────────────────
PRICE_LOCK_DURATION="10"
DEFAULT_MARKUP_PERCENT="20"
AVAILABILITY_CACHE_TTL="15"
